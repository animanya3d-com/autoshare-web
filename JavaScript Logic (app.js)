// AutoShare - YouTube to Instagram & TikTok
// Configuration and API Integration

const CONFIG = {
    CREAO_ENDPOINT: 'https://api.creao.ai/v1/miniapp/wdJ9GXUpU4/run',
    DEMO_MODE: false,
};

// Form Elements
const form = document.getElementById('autoshareForm');
const submitBtn = document.getElementById('submitBtn');
const resultsSection = document.getElementById('results');
const errorSection = document.getElementById('error');
const loadingSection = document.getElementById('loading');

// Form Submit Handler
form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Hide previous results/errors
    resultsSection.classList.add('hidden');
    errorSection.classList.add('hidden');
    loadingSection.classList.remove('hidden');
    submitBtn.disabled = true;

    // Collect form data
    const formData = {
        youtube_url: document.getElementById('youtubeUrl').value,
        video_title: document.getElementById('videoTitle').value,
        video_description: document.getElementById('videoDescription').value,
        prepare_instagram_reels: document.getElementById('prepareInstagram').checked,
        upload_to_tiktok: document.getElementById('uploadTiktok').checked,
        tiktok_access_token: document.getElementById('tiktokToken').value || undefined
    };

    try {
        if (CONFIG.DEMO_MODE) {
            // Demo mode - show sample response
            await new Promise(resolve => setTimeout(resolve, 2000));
            showDemoResults(formData);
        } else {
            // Real API call
            const response = await fetch(CONFIG.CREAO_ENDPOINT, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(formData)
            });

            if (!response.ok) {
                throw new Error(`API Error: ${response.status} ${response.statusText}`);
            }

            const result = await response.json();
            showResults(result);
        }
    } catch (error) {
        showError(error.message);
    } finally {
        loadingSection.classList.add('hidden');
        submitBtn.disabled = false;
    }
});

// Show Results
function showResults(data) {
    const resultsContent = document.getElementById('resultsContent');
    
    let html = '<div class="space-y-4">';
    
    // Instagram Reels Section
    if (data.instagram_reels && data.instagram_reels.status === 'ready') {
        html += `
            <div class="result-card">
                <h3 class="text-lg font-semibold text-green-600 mb-2">
                    ✅ Instagram Reels Hazır
                </h3>
                <p class="text-sm text-gray-600 mb-3">${data.instagram_reels.note || ''}</p>
                <a href="${data.instagram_reels.download_url}" 
                   target="_blank"
                   class="inline-block bg-gradient-to-r from-purple-500 to-pink-500 text-white px-6 py-2 rounded-lg hover:from-purple-600 hover:to-pink-600 transition">
                    📥 Videoyu İndir (${data.instagram_reels.file_size_mb} MB)
                </a>
                <div class="mt-3 text-sm text-gray-600">
                    <p><strong>Çözünürlük:</strong> ${data.instagram_reels.resolution}</p>
                    <p><strong>Süre:</strong> ${data.instagram_reels.duration_seconds} saniye</p>
                </div>
            </div>
        `;
    }
    
    // TikTok Section
    if (data.tiktok) {
        if (data.tiktok.status === 'uploaded') {
            html += `
                <div class="result-card">
                    <h3 class="text-lg font-semibold text-green-600 mb-2">
                        ✅ TikTok'a Yüklendi
                    </h3>
                    <p class="text-sm text-gray-600">
                        Video ID: ${data.tiktok.publish_id}
                    </p>
                    <p class="text-xs text-yellow-600 mt-2">
                        ⚠️ Video uygulamanız onaylanana kadar gizli olabilir
                    </p>
                </div>
            `;
        } else if (data.tiktok.status === 'skipped') {
            html += `
                <div class="result-card bg-gray-50">
                    <h3 class="text-lg font-semibold text-gray-600 mb-2">
                        ⏭️ TikTok Atlandı
                    </h3>
                    <p class="text-sm text-gray-600">${data.tiktok.reason}</p>
                </div>
            `;
        }
    }
    
    // Summary
    if (data.summary && data.summary.operations_completed) {
        html += `
            <div class="result-card bg-blue-50">
                <h3 class="text-lg font-semibold text-blue-600 mb-2">
                    📊 Özet
                </h3>
                <ul class="text-sm text-gray-700 space-y-1">
                    ${data.summary.operations_completed.map(op => `<li>${op}</li>`).join('')}
                </ul>
            </div>
        `;
    }
    
    html += '</div>';
    
    resultsContent.innerHTML = html;
    resultsSection.classList.remove('hidden');
}

// Show Demo Results
function showDemoResults(formData) {
    const demoData = {
        instagram_reels: {
            status: 'ready',
            download_url: '#',
            file_size_mb: 10.5,
            resolution: '1080x1920',
            duration_seconds: 60,
            note: '✨ DEMO MOD: Gerçek API bağlantısı için app.js dosyasını güncelleyin'
        },
        tiktok: {
            status: formData.upload_to_tiktok ? 'uploaded' : 'skipped',
            reason: formData.upload_to_tiktok ? null : 'Kullanıcı tarafından devre dışı bırakıldı',
            publish_id: formData.upload_to_tiktok ? 'demo_12345' : null
        },
        summary: {
            operations_completed: [
                '✅ Demo video oluşturuldu',
                '✅ Instagram Reels formatı hazır',
                formData.upload_to_tiktok ? '✅ TikTok\'a yükleme simülasyonu' : '⏭️ TikTok atlandı'
            ]
        }
    };
    
    showResults(demoData);
}

// Show Error
function showError(message) {
    const errorContent = document.getElementById('errorContent');
    errorContent.textContent = message;
    errorSection.classList.remove('hidden');
}

// Toggle TikTok Token Field
document.getElementById('uploadTiktok').addEventListener('change', (e) => {
    const tokenField = document.getElementById('tiktokTokenField');
    if (e.target.checked) {
        tokenField.classList.remove('hidden');
    } else {
        tokenField.classList.add('hidden');
    }
});
